<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FIAE2GO.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="FIAE2GO.Views.QuizView"
             x:DataType="vm:QuizViewModel">
  
  <Grid>
    <ScrollViewer>
      <StackPanel Spacing="15" Margin="20" MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsReady}">
        <TextBlock Text="{Binding ProgressText}" HorizontalAlignment="Center" Opacity="0.7" />
        
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,10">
          <TextBlock Text="{Binding CurrentQuestion.QuestionText, FallbackValue=''}" TextWrapping="Wrap" FontSize="18" FontWeight="SemiBold"/>
        </Border>
        
        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto,Auto,Auto,Auto">
          <CheckBox Grid.Row="0" Grid.Column="0" Content="{Binding CurrentQuestion.OptionA, FallbackValue=''}" IsChecked="{Binding IsOptionASelected}" IsEnabled="{Binding !IsResultMode}" Margin="0,5"/>
          <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="✅" IsVisible="{Binding IsOptionACorrect}" FontSize="20"/>
            <TextBlock Text="❌" IsVisible="{Binding IsOptionAWrong}" FontSize="20"/>
          </StackPanel>

          <CheckBox Grid.Row="1" Grid.Column="0" Content="{Binding CurrentQuestion.OptionB, FallbackValue=''}" IsChecked="{Binding IsOptionBSelected}" IsEnabled="{Binding !IsResultMode}" Margin="0,5"/>
          <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="✅" IsVisible="{Binding IsOptionBCorrect}" FontSize="20"/>
            <TextBlock Text="❌" IsVisible="{Binding IsOptionBWrong}" FontSize="20"/>
          </StackPanel>

          <CheckBox Grid.Row="2" Grid.Column="0" Content="{Binding CurrentQuestion.OptionC, FallbackValue=''}" IsChecked="{Binding IsOptionCSelected}" IsEnabled="{Binding !IsResultMode}" Margin="0,5"/>
          <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="✅" IsVisible="{Binding IsOptionCCorrect}" FontSize="20"/>
            <TextBlock Text="❌" IsVisible="{Binding IsOptionCWrong}" FontSize="20"/>
          </StackPanel>

          <CheckBox Grid.Row="3" Grid.Column="0" Content="{Binding CurrentQuestion.OptionD, FallbackValue=''}" IsChecked="{Binding IsOptionDSelected}" IsEnabled="{Binding !IsResultMode}" Margin="0,5"/>
          <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="✅" IsVisible="{Binding IsOptionDCorrect}" FontSize="20"/>
            <TextBlock Text="❌" IsVisible="{Binding IsOptionDWrong}" FontSize="20"/>
          </StackPanel>
        </Grid>
        
        <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center" Margin="0,20,0,0">
          <Button Content="Zurück" Command="{Binding PreviousCommand}" IsVisible="{Binding CanGoBack}"><Image Source="/Assets/previous.png" Width="32"/></Button>
          <Button Command="{Binding NextCommand}" Classes="accent" FontWeight="Bold">
            <Image Source="/Assets/next.png" Width="32"/>
          </Button>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
    <Button Command="{Binding CancelCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20">
      <Image Source="/Assets/close.png" Width="32"/>
    </Button>
  </Grid>
</UserControl>