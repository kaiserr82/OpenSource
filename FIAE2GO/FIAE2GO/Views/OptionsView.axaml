<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FIAE2GO.ViewModels"
             x:Class="FIAE2GO.Views.OptionsView"
             x:DataType="vm:OptionsViewModel">
    <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Optionen" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Padding="15" BorderBrush="Gray" BorderThickness="1" CornerRadius="5" MinWidth="350">
            <StackPanel Spacing="15">
                <TextBlock Text="Standardeinstellungen" FontWeight="Bold"/>
                
                <TextBlock Text="Standardmäßige Anzahl der Fragen:"/>
                <NumericUpDown Value="{Binding DefaultQuestionCount}" Minimum="5" Maximum="50" Increment="1" FormatString="0" />

                <TextBlock Text="Verfügbare Fragen in der Datenbank:" Margin="0,10,0,0"/>
                <TextBlock Text="{Binding TotalQuestionCount}" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <Button Command="{Binding CopyDatabaseCommand}" IsEnabled="{Binding IsDatabaseCopySupported}"
                HorizontalAlignment="Center" MinWidth="250" ToolTip.Tip="Öffnet einen Dialog zur Auswahl einer Datenbank-Datei (.db) zum Importieren.">
                <Image Source="avares://FIAE2GO/Assets/switch.png" Width="32"/>
                </Button>

        <Button Command="{Binding GoBackCommand}" HorizontalAlignment="Center" MinWidth="150" Margin="0,20,0,0">
            <Image Source="avares://FIAE2GO/Assets/previous.png" Width="32"/>
                </Button>
    </StackPanel>
</UserControl>